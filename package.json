{
  "name": "bossguide",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "validate:teams": "npx ts-node scripts/validateTeams.ts",
    "scrape:prydwen": "node scripts/scrapePrydwen.js",
    "scrape:builds": "node scripts/scrapeBuildData.js",
    "scrape:builds:test": "node scripts/scrapeBuildData.js --character hyacine",
    "scrape:builds:char": "node scripts/scrapeBuildData.js",
    "generate:characters": "node scripts/generateCharacters.js",
    "update:characters": "npm run scrape:prydwen && npm run generate:characters",
    "update:builds": "npm run scrape:builds && npm run merge:builds",
    "merge:builds": "node scripts/mergeBuildData.js",
    "palette:characters": "node scripts/extractCharacterPalettes.js",
    "merge:tiers": "node scripts/mergeTierData.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^6.5.7",
    "@react-navigation/native": "^6.1.6",
    "@react-navigation/stack": "^6.3.16",
    "expo": "~54.0.33",
    "expo-notifications": "~0.32.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "sharp": "^0.33.5",
    "typescript": "~5.9.2"
  }
}